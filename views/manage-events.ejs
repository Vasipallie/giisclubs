    <!-- Main Content -->
    <main class="main-content">
        <div class="content-area">
            <div class="container">
        <div class="page-header">
            <h1 class="page-title"><%= isAdmin ? 'Manage All Club Events' : 'Manage Your Events' %></h1>
            <p class="page-subtitle"><%= isAdmin ? 'View all events and their submission status' : 'Submit budgets and receipts for approved events' %></p>
        </div>

        <% if (message) { %>
            <div class="message"><%= message %></div>
        <% } %>
        <% if (error) { %>
            <div class="error"><%= error %></div>
        <% } %>

        <div id="events-container" class="events-list">
            <div class="loading">
                <div class="spinner"></div>
                <p style="margin-top: 16px;">Loading your events...</p>
            </div>
        </div>

        <div class="schedule-section">
            <div class="schedule-title">Event Timeline & Calendar</div>
            <div class="schedule-subtitle">Approved events are your confirmed schedule. Pending events stay visible until approved.</div>
            <div class="calendar-wrap">
                <div id="calendar-grid" class="calendar-grid"></div>
            </div>
            <div id="timeline-list" class="timeline-list"></div>
        </div>
    </div>

    <script>
        function formatDateDDMMYYYY(dateString) {
            const date = new Date(dateString);
            const day = String(date.getDate()).padStart(2, '0');
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const year = date.getFullYear();
            return `${day}/${month}/${year}`;
        }

        async function loadEvents() {
            const container = document.getElementById('events-container');
            
            try {
                const response = await fetch('/api/my-events');
                const events = await response.json();

                if (events.length === 0) {
                    container.innerHTML = `
                        <div style="grid-column: 1 / -1;">
                            <div class="empty-state">
                                <div class="empty-state-icon">📋</div>
                                <div class="empty-state-title">No events yet</div>
                                <div class="empty-state-text">Create an event to get started</div>
                            </div>
                        </div>
                    `;
                    renderSchedule([]);
                    return;
                }

                container.innerHTML = events.map(event => `
                    <a href="/manage-events/${event.id}" class="event-bar">
                        <div class="event-main">
                            <div class="event-title">${event.event_name || event.description}</div>
                            <div class="event-meta">
                                <span>Date: ${formatDateDDMMYYYY(event.date)}</span>
                                ${event.target_grades ? `<span>Grades: ${event.target_grades}</span>` : ''}
                            </div>
                        </div>
                        <div class="event-status">
                            <span class="status-badge ${event.approved ? 'status-approved' : 'status-pending'}">
                                ${event.approved ? 'Approved' : 'Pending'}
                            </span>
                            <span class="status-badge ${event.budget_submitted ? 'status-submitted' : 'status-pending-submit'}">
                                ${event.budget_submitted ? 'Budget Submitted' : 'Budget Pending'}
                            </span>
                            <span class="status-badge ${event.receipts_submitted ? 'status-submitted' : 'status-pending-submit'}">
                                ${event.receipts_submitted ? 'Receipts Submitted' : 'Receipts Pending'}
                            </span>
                            <span class="bar-arrow">→</span>
                        </div>
                    </a>
                `).join('');
                renderSchedule(events);
            } catch (error) {
                console.error('Error loading events:', error);
                container.innerHTML = `
                    <div style="grid-column: 1 / -1;">
                        <div class="error">Failed to load events. Please try again.</div>
                    </div>
                `;
                renderSchedule([]);
            }
        }

        function renderSchedule(events) {
            const calendarGrid = document.getElementById('calendar-grid');
            const timelineList = document.getElementById('timeline-list');

            const now = new Date();
            const year = now.getFullYear();
            const month = now.getMonth();

            const firstDay = new Date(year, month, 1);
            const firstWeekday = firstDay.getDay();
            const daysInMonth = new Date(year, month + 1, 0).getDate();

            const weekdayLabels = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
            const byDate = {};

            events.forEach(event => {
                const eventDate = new Date(event.date);
                if (eventDate.getFullYear() === year && eventDate.getMonth() === month) {
                    const day = eventDate.getDate();
                    if (!byDate[day]) byDate[day] = [];
                    byDate[day].push(event);
                }
            });

            const headHtml = weekdayLabels.map(label => `<div class="calendar-head">${label}</div>`).join('');
            let cellsHtml = '';

            for (let i = 0; i < firstWeekday; i++) {
                cellsHtml += '<div class="calendar-cell"></div>';
            }

            for (let day = 1; day <= daysInMonth; day++) {
                const dayEvents = byDate[day] || [];
                const tagHtml = dayEvents.slice(0, 2).map(event => `
                    <div class="calendar-tag ${event.approved ? 'approved' : 'pending'}" title="${event.event_name || event.description}">
                        ${event.event_name || event.description}
                    </div>
                `).join('');
                const moreTag = dayEvents.length > 2 ? `<div class="calendar-tag pending">+${dayEvents.length - 2} more</div>` : '';

                cellsHtml += `
                    <div class="calendar-cell">
                        <div class="calendar-day">${day}</div>
                        ${tagHtml}
                        ${moreTag}
                    </div>
                `;
            }

            calendarGrid.innerHTML = headHtml + cellsHtml;

            const sorted = [...events].sort((a, b) => new Date(a.date) - new Date(b.date));
            if (sorted.length === 0) {
                timelineList.innerHTML = '<div class="empty-state-text">No events available for timeline yet.</div>';
                return;
            }

            timelineList.innerHTML = sorted.map(event => `
                <div class="timeline-item">
                    <div>
                        <div class="timeline-name">${event.event_name || event.description}</div>
                        <div>${event.target_grades ? `Grades: ${event.target_grades}` : 'No grade filter'}</div>
                    </div>
                    <div>
                        <div>${formatDateDDMMYYYY(event.date)}</div>
                        <span class="status-badge ${event.approved ? 'status-approved' : 'status-pending'}">${event.approved ? 'Approved' : 'Pending'}</span>
                    </div>
                </div>
            `).join('');
        }

        // Load events on page load
        loadEvents();

        function toggleSidebar() {
            document.querySelector('.sidebar').classList.toggle('open');
            document.querySelector('.sidebar-overlay').classList.toggle('open');
        }
    </script>
        </div>
    </main>
</body>
</html>
