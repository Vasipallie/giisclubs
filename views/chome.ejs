<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GIIS Clubs | Dashboard</title>
    <link rel="icon" type="image/png" href="resources/1.png">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --ink: #0f172a;
            --muted: #64748b;
            --surface: #ffffff;
            --surface-soft: #f8fafc;
            --border: #e2e8f0;
            --sidebar-width: 260px;
        }
        
        body {
            font-family: 'Poppins', sans-serif;
            line-height: 1.6;
            color: var(--ink);
            background-color: var(--surface-soft);
        }

        /* Sidebar */
        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            width: var(--sidebar-width);
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 24px;
            border-bottom: 1px solid var(--border);
        }

        .sidebar-logo {
            height: 48px;
            width: auto;
        }

        .sidebar-nav {
            flex: 1;
            padding: 16px 0;
            overflow-y: auto;
        }

        .nav-section {
            margin-bottom: 8px;
        }

        .nav-section-title {
            padding: 8px 24px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--muted);
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 24px;
            color: var(--ink);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            border-left: 3px solid transparent;
        }

        .nav-link:hover {
            background: var(--surface-soft);
            color: var(--primary);
        }

        .nav-link.active {
            background: rgba(37, 99, 235, 0.08);
            color: var(--primary);
            border-left-color: var(--primary);
            font-weight: 600;
        }

        .nav-icon {
            width: 20px;
            height: 20px;
            stroke: currentColor;
            stroke-width: 2;
            fill: none;
        }

        .sidebar-footer {
            padding: 16px 24px;
            border-top: 1px solid var(--border);
        }

        .club-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .club-avatar {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 16px;
        }

        .club-avatar-img {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            object-fit: cover;
        }

        .club-details {
            flex: 1;
            min-width: 0;
        }

        .club-name {
            font-size: 14px;
            font-weight: 600;
            color: var(--ink);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .club-status {
            font-size: 12px;
            color: var(--muted);
        }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
        }

        .page-header {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 24px 32px;
        }

        .page-header-content {
            max-width: 1200px;
        }

        .page-title {
            font-size: 24px;
            font-weight: 700;
            color: var(--ink);
            margin-bottom: 4px;
        }

        .page-subtitle {
            font-size: 14px;
            color: var(--muted);
        }

        .content-area {
            padding: 32px;
            max-width: 1200px;
        }

        .section-title {
            font-size: 16px;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: 16px;
        }

        /* Cards Grid */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 24px;
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .card:hover {
            border-color: var(--primary);
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1);
        }

        .card-icon {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            background: rgba(37, 99, 235, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 16px;
        }

        .card-icon svg {
            width: 22px;
            height: 22px;
            stroke: var(--primary);
            stroke-width: 2;
            fill: none;
        }

        .card-title {
            font-size: 16px;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: 8px;
        }

        .card-description {
            font-size: 14px;
            color: var(--muted);
            line-height: 1.5;
        }

        .card-action {
            margin-top: 16px;
            font-size: 13px;
            font-weight: 600;
            color: var(--primary);
        }

        .admin-panel {
            margin-top: 28px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
        }

        .admin-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--ink);
            margin-bottom: 6px;
        }

        .admin-subtitle {
            font-size: 13px;
            color: var(--muted);
            margin-bottom: 16px;
        }

        .admin-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .admin-card {
            background: var(--surface-soft);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 14px;
        }

        .admin-card h3 {
            font-size: 15px;
            margin-bottom: 10px;
            color: var(--ink);
        }

        .admin-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
            max-height: 300px;
            overflow-y: auto;
        }

        .admin-item {
            padding: 10px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: #fff;
            display: flex;
            justify-content: space-between;
            gap: 10px;
            align-items: center;
            font-size: 13px;
        }

        .admin-item strong {
            color: #1e3a8a;
            display: block;
        }

        .admin-actions {
            display: flex;
            gap: 6px;
        }

        .admin-btn {
            border: none;
            border-radius: 6px;
            padding: 6px 10px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
        }

        .admin-btn.approve {
            background: #dcfce7;
            color: #166534;
        }

        .admin-btn.delete {
            background: #fee2e2;
            color: #991b1b;
        }

        .calendar-mini {
            margin-top: 12px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .calendar-item {
            padding: 10px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: #fff;
            font-size: 13px;
        }

        /* Mobile Toggle */
        .mobile-toggle {
            display: none;
            position: fixed;
            top: 16px;
            left: 16px;
            z-index: 1001;
            width: 44px;
            height: 44px;
            border-radius: 10px;
            background: var(--surface);
            border: 1px solid var(--border);
            cursor: pointer;
            align-items: center;
            justify-content: center;
        }

        .mobile-toggle svg {
            width: 24px;
            height: 24px;
            stroke: var(--ink);
            stroke-width: 2;
            fill: none;
        }

        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 999;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }

            .sidebar.open {
                transform: translateX(0);
            }

            .sidebar-overlay.open {
                display: block;
            }

            .main-content {
                margin-left: 0;
            }

            .mobile-toggle {
                display: flex;
            }

            .page-header {
                padding: 24px 16px;
                padding-top: 72px;
            }

            .content-area {
                padding: 24px 16px;
            }

            .cards-grid {
                grid-template-columns: 1fr;
            }

            .admin-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
    <style>
        /* Logout Button Styles */
        .logout-btn {
            width: 100%;
            padding: 10px 0;
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: 6px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 8px;
            transition: background 0.2s;
        }
        .logout-btn:hover {
            background: var(--primary-dark);
        }
    </style>
</head>
<body>
    <!-- Mobile Toggle -->
    <button class="mobile-toggle" onclick="toggleSidebar()">
        <svg viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>

    <!-- Sidebar Overlay -->
    <div class="sidebar-overlay" onclick="toggleSidebar()"></div>

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <a href="/">
                <img src="resources/2.png" alt="GIIS Clubs" class="sidebar-logo">
            </a>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section">
                <div class="nav-section-title">Main</div>
                <a href="/home" class="nav-link active">
                    <svg class="nav-icon" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    Dashboard
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">Events</div>
                <a href="/calendar" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Calendar
                </a>
                <a href="/events" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    All Club Events
                </a>
                <a href="/add-event" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Create Event
                </a>
                <a href="/manage-events" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                    Manage My Events
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">Tools</div>
                <a href="/shorten" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                    URL Shortener
                </a>
                <a href="/qrgen" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    QR Generator
                </a>
                <a href="/linklist-manager" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                    Linklist Manager
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">Settings</div>
                <a href="/manage-club" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                    Manage Club
                </a>
                <% if (isAdmin) { %>
                <a href="/home#admin-tools" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                    Admin Tools
                </a>
                <% } %>
            </div>
        </nav>

        <div class="sidebar-footer">
            <div class="club-info">
                <% if (clubLogo) { %>
                    <img src="<%= clubLogo %>" alt="Club Logo" class="club-avatar-img">
                <% } else { %>
                    <div class="club-avatar"><%= clubName ? clubName.charAt(0).toUpperCase() : 'C' %></div>
                <% } %>
                <div class="club-details">
                    <div class="club-name"><%= clubName || 'Your Club' %></div>
                    <div class="club-status">@ PG SMART CAMPUS</div>
                </div>
            </div>
            <form action="/logout" method="POST" style="margin-top: 18px;">
                <button type="submit" class="logout-btn">Logout</button>
            </form>
        </div>
        
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <div class="page-header">
            <div class="page-header-content">
                <h1 class="page-title">Welcome back<%= clubName ? ', ' + clubName : '' %>!</h1>
                <p class="page-subtitle">Manage your club's digital presence from one place</p>
            </div>

            </div>
        </div>

        <div class="content-area">
            <% if (isAdmin) { %>
            <section id="admin-tools" class="admin-panel">
                <div class="admin-title">Admin Tools</div>
                <div class="admin-subtitle">Manage approvals and users before jumping into quick links.</div>

                <div class="admin-grid">
                    <div class="admin-card">
                        <h3>Pending Event Approvals</h3>
                        <div id="admin-event-list" class="admin-list"></div>
                    </div>

                    <div class="admin-card">
                        <h3>Registered Clubs</h3>
                        <div id="admin-user-list" class="admin-list"></div>
                    </div>
                </div>

                <div class="admin-card" style="margin-top: 16px;">
                    <h3>Event Calendar</h3>
                    <div class="calendar-mini">
                        <a href="/calendar" class="card" style="padding: 14px;">
                            <h4 class="card-title" style="margin-bottom: 6px;">Open Upcoming Events Calendar</h4>
                            <p class="card-description">Approved events are auto-included by event date.</p>
                            <div class="card-action">Open Calendar</div>
                        </a>
                    </div>
                </div>
            </section>
            <% } %>

            <h2 class="section-title">Quick Actions</h2>
            <div class="cards-grid">
                <a href="/calendar" class="card">
                    <div class="card-icon">
                        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    </div>
                    <h3 class="card-title">Events Calendar</h3>
                    <p class="card-description">View upcoming approved events in a monthly calendar schedule.</p>
                    <div class="card-action">Open Calendar</div>
                </a>

                <a href="/shorten" class="card">
                    <div class="card-icon">
                        <svg viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                    </div>
                    <h3 class="card-title">URL Shortener</h3>
                    <p class="card-description">Create and manage shortened links for your club's social media, events, and communications.</p>
                    <div class="card-action">Manage Links</div>
                </a>

                <a href="/qrgen" class="card">
                    <div class="card-icon">
                        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    </div>
                    <h3 class="card-title">QR Generator</h3>
                    <p class="card-description">Generate professional QR codes for events, membership drives, and quick access to resources.</p>
                    <div class="card-action">Generate QR Codes</div>
                </a>

                <a href="/linklist-manager" class="card">
                    <div class="card-icon">
                        <svg viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                    </div>
                    <h3 class="card-title">Linklist Manager</h3>
                    <p class="card-description">Create and manage a centralized hub for all your club's important links and resources.</p>
                    <div class="card-action">Manage Linklist</div>
                </a>

                <a href="/manage-club" class="card">
                    <div class="card-icon">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                    </div>
                    <h3 class="card-title">Manage Club</h3>
                    <p class="card-description">Edit your club profile, update descriptions, and manage your branding assets.</p>
                    <div class="card-action">Manage Profile</div>
                </a>

                <a href="/explore" class="card">
                    <div class="card-icon">
                        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    </div>
                    <h3 class="card-title">Explore Clubs</h3>
                    <p class="card-description">Browse other registered clubs and organizations to discover collaboration opportunities.</p>
                    <div class="card-action">Explore Now</div>
                </a>
            </div>

        </div>
    </main>

    <script>
        function toggleSidebar() {
            document.querySelector('.sidebar').classList.toggle('open');
            document.querySelector('.sidebar-overlay').classList.toggle('open');
        }

        function formatDate(dateString) {
            const date = new Date(dateString);
            return date.toLocaleDateString('en-GB');
        }

        async function loadAdminData() {
            const eventList = document.getElementById('admin-event-list');
            const userList = document.getElementById('admin-user-list');
            if (!eventList || !userList) return;

            eventList.innerHTML = '<div class="admin-item">Loading events...</div>';
            userList.innerHTML = '<div class="admin-item">Loading users...</div>';

            try {
                const [eventsResponse, usersResponse] = await Promise.all([
                    fetch('/admin/events'),
                    fetch('/admin/users')
                ]);

                const events = eventsResponse.ok ? await eventsResponse.json() : [];
                const users = usersResponse.ok ? await usersResponse.json() : [];

                const pendingEvents = events.filter(event => !event.approved);
                if (pendingEvents.length === 0) {
                    eventList.innerHTML = '<div class="admin-item">No pending approvals.</div>';
                } else {
                    eventList.innerHTML = pendingEvents.map(event => `
                        <div class="admin-item">
                            <div>
                                <strong>${event.event_name || event.description}</strong>
                                <div>${event.club} • ${formatDate(event.date)}</div>
                            </div>
                            <div class="admin-actions">
                                <button class="admin-btn approve" onclick="approveEvent('${event.id}')">Approve</button>
                                <button class="admin-btn delete" onclick="deleteEvent('${event.id}')">Delete</button>
                            </div>
                        </div>
                    `).join('');
                }

                const visibleUsers = users.filter(user => !user.is_admin);
                if (visibleUsers.length === 0) {
                    userList.innerHTML = '<div class="admin-item">No clubs found.</div>';
                } else {
                    userList.innerHTML = visibleUsers.map(user => `
                        <div class="admin-item">
                            <div>
                                <strong>${user.name}</strong>
                                <div>${user.description || 'No description'}</div>
                            </div>
                        </div>
                    `).join('');
                }
            } catch (error) {
                eventList.innerHTML = '<div class="admin-item">Failed to load admin data.</div>';
                userList.innerHTML = '<div class="admin-item">Failed to load admin data.</div>';
            }
        }

        async function approveEvent(eventId) {
            if (!confirm('Approve this event and add it to calendar timeline?')) return;
            try {
                const response = await fetch(`/admin/events/${eventId}/approve`, { method: 'PUT' });
                const result = await response.json();
                if (!response.ok) {
                    alert(result.error || 'Failed to approve event');
                    return;
                }
                loadAdminData();
            } catch (error) {
                alert('Network error. Please try again.');
            }
        }

        async function deleteEvent(eventId) {
            if (!confirm('Delete this event?')) return;
            try {
                const response = await fetch(`/admin/events/${eventId}`, { method: 'DELETE' });
                const result = await response.json();
                if (!response.ok) {
                    alert(result.error || 'Failed to delete event');
                    return;
                }
                loadAdminData();
            } catch (error) {
                alert('Network error. Please try again.');
            }
        }

        loadAdminData();
    </script>
</body>
</html>