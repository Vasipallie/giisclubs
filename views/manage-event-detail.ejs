<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Event Details | GIIS Clubs</title>
    <link rel="icon" type="image/png" href="/resources/1.png">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --ink: #0f172a;
            --muted: #64748b;
            --surface: #ffffff;
            --surface-soft: #f8fafc;
            --border: #e2e8f0;
            --sidebar-width: 260px;
        }

        body {
            font-family: 'Poppins', sans-serif;
            line-height: 1.6;
            color: var(--ink);
            background-color: var(--surface-soft);
        }

        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            width: var(--sidebar-width);
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 24px;
            border-bottom: 1px solid var(--border);
        }

        .sidebar-logo {
            height: 48px;
            width: auto;
        }

        .sidebar-nav {
            flex: 1;
            padding: 16px 0;
            overflow-y: auto;
        }

        .nav-section {
            margin-bottom: 8px;
        }

        .nav-section-title {
            padding: 8px 24px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--muted);
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 24px;
            color: var(--ink);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            border-left: 3px solid transparent;
        }

        .nav-link:hover {
            background: var(--surface-soft);
            color: var(--primary);
        }

        .nav-link.active {
            background: rgba(37, 99, 235, 0.08);
            color: var(--primary);
            border-left-color: var(--primary);
            font-weight: 600;
        }

        .nav-icon {
            width: 20px;
            height: 20px;
            stroke: currentColor;
            stroke-width: 2;
            fill: none;
        }

        .sidebar-footer {
            padding: 16px 24px;
            border-top: 1px solid var(--border);
        }

        .club-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .club-avatar {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 16px;
        }

        .club-avatar-img {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            object-fit: cover;
        }

        .club-details {
            flex: 1;
            min-width: 0;
        }

        .club-name {
            font-size: 14px;
            font-weight: 600;
            color: var(--ink);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .club-status {
            font-size: 12px;
            color: var(--muted);
        }

        .logout-btn {
            width: 100%;
            padding: 10px 0;
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: 6px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 8px;
            transition: background 0.2s;
        }

        .logout-btn:hover {
            background: var(--primary-dark);
        }

        .main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
        }

        .content-area {
            padding: 32px;
            max-width: 1100px;
        }

        .mobile-toggle {
            display: none;
            position: fixed;
            top: 16px;
            left: 16px;
            z-index: 1001;
            width: 44px;
            height: 44px;
            border-radius: 10px;
            background: var(--surface);
            border: 1px solid var(--border);
            cursor: pointer;
            align-items: center;
            justify-content: center;
        }

        .mobile-toggle svg {
            width: 24px;
            height: 24px;
            stroke: var(--ink);
            stroke-width: 2;
            fill: none;
        }

        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 999;
        }

        .page-header {
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .page-title {
            font-size: 28px;
            font-weight: 700;
            color: #2563eb;
            margin-bottom: 8px;
        }

        .page-subtitle {
            font-size: 14px;
            color: #64748b;
        }

        .back-link {
            text-decoration: none;
            color: #2563eb;
            font-size: 14px;
            font-weight: 600;
        }

        .back-link:hover {
            text-decoration: underline;
        }

        .event-summary {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 12px;
            margin-top: 12px;
        }

        .summary-item {
            font-size: 14px;
            color: #334155;
        }

        .summary-item strong {
            color: #1e3a8a;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            margin-left: 8px;
        }

        .status-pending {
            background: #fef3c7;
            color: #92400e;
        }

        .status-approved {
            background: #d1fae5;
            color: #065f46;
        }

        .panel-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .panel {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 18px;
        }

        .panel h3 {
            font-size: 16px;
            color: #1e3a8a;
            margin-bottom: 10px;
        }

        .panel-note {
            font-size: 13px;
            color: #64748b;
            margin-bottom: 12px;
        }

        .file-input {
            width: 100%;
            padding: 8px;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            font-size: 12px;
            margin-bottom: 10px;
        }

        .submit-btn {
            width: 100%;
            padding: 10px;
            background: #2563eb;
            color: #fff;
            border: none;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
        }

        .submit-btn:hover {
            background: #1d4ed8;
        }

        .file-list {
            margin-top: 14px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .file-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding: 10px 12px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
        }

        .file-link {
            color: #2563eb;
            text-decoration: none;
            font-size: 13px;
            word-break: break-word;
        }

        .file-link:hover {
            text-decoration: underline;
        }

        .remove-btn {
            border: 1px solid #fecaca;
            background: #fff1f2;
            color: #b91c1c;
            border-radius: 6px;
            font-size: 12px;
            padding: 6px 10px;
            cursor: pointer;
            white-space: nowrap;
        }

        .remove-btn:hover {
            background: #ffe4e6;
        }

        .empty-files {
            font-size: 13px;
            color: #64748b;
        }

        .warning-box {
            margin-top: 16px;
            padding: 12px;
            border-radius: 8px;
            background: #fef3c7;
            color: #92400e;
            font-size: 13px;
            border-left: 4px solid #f59e0b;
        }

        @media (max-width: 900px) {
            .panel-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }

            .sidebar.open {
                transform: translateX(0);
            }

            .sidebar-overlay.open {
                display: block;
            }

            .main-content {
                margin-left: 0;
            }

            .mobile-toggle {
                display: flex;
            }

            .content-area {
                padding: 24px 16px;
                padding-top: 72px;
            }
        }
    </style>
</head>
<body>
    <button class="mobile-toggle" onclick="toggleSidebar()">
        <svg viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>

    <div class="sidebar-overlay" onclick="toggleSidebar()"></div>

    <aside class="sidebar">
        <div class="sidebar-header">
            <a href="/">
                <img src="/resources/2.png" alt="GIIS Clubs" class="sidebar-logo">
            </a>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section">
                <div class="nav-section-title">Main</div>
                <a href="/home" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    Dashboard
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">Events</div>
                <a href="/events" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    All Club Events
                </a>
                <a href="/add-event" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Create Event
                </a>
                <a href="/manage-events" class="nav-link active">
                    <svg class="nav-icon" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                    Manage My Events
                </a>
                <a href="/calendar" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Calendar
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">Tools</div>
                <a href="/shorten" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                    URL Shortener
                </a>
                <a href="/qrgen" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    QR Generator
                </a>
                <a href="/linklist-manager" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                    Linklist Manager
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">Settings</div>
                <a href="/manage-club" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                    Manage Club
                </a>
                <% if (isAdmin) { %>
                <a href="/home#admin-tools" class="nav-link">
                    <svg class="nav-icon" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                    Admin Tools
                </a>
                <% } %>
            </div>
        </nav>

        <div class="sidebar-footer">
            <div class="club-info">
                <% if (clubLogo) { %>
                    <img src="<%= clubLogo %>" alt="Club Logo" class="club-avatar-img">
                <% } else { %>
                    <div class="club-avatar"><%= clubName ? clubName.charAt(0).toUpperCase() : 'C' %></div>
                <% } %>
                <div class="club-details">
                    <div class="club-name"><%= clubName || 'Your Club' %></div>
                    <div class="club-status">@ PG SMART CAMPUS</div>
                </div>
            </div>
            <form action="/logout" method="POST" style="margin-top: 18px;">
                <button type="submit" class="logout-btn">Logout</button>
            </form>
        </div>
    </aside>

    <main class="main-content">
        <div class="content-area">
            <div class="page-header">
                <div>
                    <h1 class="page-title"><%= event.event_name || 'Event Details' %></h1>
                    <p class="page-subtitle">Manage details and submissions for this event</p>
                </div>
                <a href="/manage-events" class="back-link">← Back to all events</a>
            </div>

            <div class="event-summary">
                <div class="summary-item">
                    <strong>Approval:</strong>
                    <span class="status-badge <%= event.approved ? 'status-approved' : 'status-pending' %>">
                        <%= event.approved ? 'Approved' : 'Pending' %>
                    </span>
                </div>
                <div class="summary-grid">
                    <div class="summary-item"><strong>Date:</strong> <%= new Date(event.date).toLocaleDateString('en-GB') %></div>
                    <div class="summary-item"><strong>Target Grades:</strong> <%= event.target_grades || 'N/A' %></div>
                    <div class="summary-item"><strong>Club:</strong> <%= event.club || clubName || 'N/A' %></div>
                    <div class="summary-item"><strong>Proposal:</strong> <a class="file-link" href="<%= event.proposal_link %>" target="_blank">Open Document</a></div>
                </div>
                <div class="summary-item" style="margin-top: 12px;"><strong>Description:</strong> <%= event.description %></div>
            </div>

            <div class="panel-grid">
                <section class="panel">
                    <h3>Budget Files</h3>
                    <p class="panel-note">Upload one file at a time. You can add more files and remove previous uploads.</p>
                    <% if (event.approved) { %>
                        <input type="file" id="budget-file" class="file-input" accept=".pdf,.xlsx,.xls,.doc,.docx" />
                        <button class="submit-btn" onclick="submitBudget('<%= event.id %>')">Upload Budget File</button>
                    <% } %>

                    <div class="file-list" id="budget-file-list">
                        <% if (budgetFiles && budgetFiles.length > 0) { %>
                            <% budgetFiles.forEach((file) => { %>
                                <div class="file-row">
                                    <a href="<%= file.url %>" target="_blank" class="file-link"><%= file.name %></a>
                                    <button class="remove-btn" onclick='removeFile("<%= event.id %>", "budget", <%- JSON.stringify(file.name) %>, <%- JSON.stringify(file.path) %>)'>Remove</button>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="empty-files">No budget files submitted yet.</div>
                        <% } %>
                    </div>
                </section>

                <section class="panel">
                    <h3>Receipt Files</h3>
                    <p class="panel-note">Upload multiple files at once. You can keep adding more files later.</p>
                    <% if (event.approved) { %>
                        <input type="file" id="receipt-files" class="file-input" accept=".pdf,.xlsx,.xls,.doc,.docx" multiple />
                        <button class="submit-btn" onclick="submitReceipts('<%= event.id %>')">Upload Receipt Files</button>
                    <% } %>

                    <div class="file-list" id="receipt-file-list">
                        <% if (receiptFiles && receiptFiles.length > 0) { %>
                            <% receiptFiles.forEach((file) => { %>
                                <div class="file-row">
                                    <a href="<%= file.url %>" target="_blank" class="file-link"><%= file.name %></a>
                                    <button class="remove-btn" onclick='removeFile("<%= event.id %>", "receipt", <%- JSON.stringify(file.name) %>, <%- JSON.stringify(file.path) %>)'>Remove</button>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="empty-files">No receipt files submitted yet.</div>
                        <% } %>
                    </div>
                </section>
            </div>

            <% if (!event.approved) { %>
                <div class="warning-box">
                    This event is still pending admin approval. File submissions are enabled after approval.
                </div>
            <% } %>
        </div>
    </main>

    <script>
        async function submitBudget(eventId) {
            const fileInput = document.getElementById('budget-file');
            const file = fileInput.files[0];

            if (!file) {
                alert('Please select a file');
                return;
            }

            const formData = new FormData();
            formData.append('file', file);

            try {
                const response = await fetch(`/events/${eventId}/budget`, {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (response.ok) {
                    alert('Budget file uploaded successfully!');
                    window.location.reload();
                } else {
                    alert(result.error || 'Failed to upload budget file');
                }
            } catch (error) {
                alert('Network error. Please try again.');
            }
        }

        async function submitReceipts(eventId) {
            const fileInput = document.getElementById('receipt-files');
            const files = fileInput.files;

            if (files.length === 0) {
                alert('Please select at least one file');
                return;
            }

            const formData = new FormData();
            for (let file of files) {
                formData.append('files', file);
            }

            try {
                const response = await fetch(`/events/${eventId}/receipts`, {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (response.ok) {
                    alert('Receipt files uploaded successfully!');
                    window.location.reload();
                } else {
                    alert(result.error || 'Failed to upload receipt files');
                }
            } catch (error) {
                alert('Network error. Please try again.');
            }
        }

        async function removeFile(eventId, type, fileName, filePath) {
            if (!confirm(`Remove this ${type} file?`)) {
                return;
            }

            try {
                const response = await fetch(`/events/${eventId}/files`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ type, fileName, filePath })
                });

                const result = await response.json();

                if (response.ok) {
                    window.location.reload();
                } else {
                    alert(result.details ? `${result.error}\n${result.details}` : (result.error || 'Failed to remove file'));
                }
            } catch (error) {
                alert('Network error. Please try again.');
            }
        }

        function toggleSidebar() {
            document.querySelector('.sidebar').classList.toggle('open');
            document.querySelector('.sidebar-overlay').classList.toggle('open');
        }
    </script>
</body>
</html>
