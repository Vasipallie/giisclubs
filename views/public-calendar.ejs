<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upcoming Events Calendar | GIIS Clubs</title>
    <link rel="icon" type="image/png" href="resources/1.png">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Poppins', sans-serif;
            background: #f8fafc;
            color: #0f172a;
        }

        .header {
            background: #ffffff;
            box-shadow: 0 2px 20px rgba(0, 0, 0, 0.1);
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
        }

        .nav-container {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 30px;
        }

        .logo-section {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo {
            height: 70px;
            width: auto;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 40px;
            list-style: none;
        }

        .nav-links a {
            color: #333;
            text-decoration: none;
            font-weight: 500;
            font-size: 16px;
            transition: all 0.3s ease;
            position: relative;
            padding: 8px 0;
        }

        .nav-links a:hover { color: #1a237e; }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, #1a237e, #3f51b5);
            transition: width 0.3s ease;
        }

        .nav-links a:hover::after { width: 100%; }

        .nav-actions { display: flex; align-items: center; gap: 16px; }

        .cta-button {
            background: linear-gradient(135deg, #1a237e 0%, #3f51b5 100%);
            color: white;
            padding: 12px 25px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
        }

        .cta-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(26, 35, 126, 0.3);
        }

        .mobile-menu-toggle {
            display: none;
            background: linear-gradient(135deg, #1a237e 0%, #3f51b5 100%);
            color: white;
            border: none;
            padding: 10px 16px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
        }

        .mobile-nav {
            position: fixed;
            top: 0;
            right: -100%;
            width: 100%;
            max-width: 320px;
            height: 100vh;
            background: #ffffff;
            z-index: 2000;
            display: flex;
            flex-direction: column;
            transition: right 0.3s ease;
            box-shadow: -4px 0 20px rgba(0,0,0,0.1);
        }

        .mobile-nav.open { right: 0; }

        .mobile-nav-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
            border-bottom: 1px solid #f0f0f0;
        }

        .mobile-nav-close {
            background: none;
            border: none;
            font-size: 18px;
            font-weight: 600;
            color: #333;
            cursor: pointer;
            padding: 8px;
        }

        .mobile-nav-links {
            list-style: none;
            padding: 0;
            margin: 0;
            flex: 1;
        }

        .mobile-nav-links li { border-bottom: 1px solid #f0f0f0; }

        .mobile-nav-links a {
            display: block;
            color: #333;
            text-decoration: none;
            font-weight: 500;
            font-size: 16px;
            padding: 18px 20px;
            transition: all 0.3s ease;
        }

        .mobile-nav-links a:hover { background: #f8f9ff; color: #1a237e; }

        .mobile-nav-cta {
            padding: 20px;
            background: #f8f9ff;
            border-top: 1px solid #f0f0f0;
        }

        .mobile-nav-cta .cta-button {
            width: 100%;
            text-align: center;
            display: block;
            padding: 15px 25px;
        }

        .mobile-nav-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.3);
            z-index: 1999;
        }

        .mobile-nav-overlay.open { display: block; }

        @media (max-width: 968px) {
            .nav-links, .nav-actions { display: none; }
            .mobile-menu-toggle { display: block; }
            .wrap { padding-top: 100px; }
        }

        .wrap {
            max-width: 1200px;
            margin: 0 auto;
            padding: 28px 20px 36px;
        }

        .title {
            font-size: 30px;
            font-weight: 700;
            color: #1d4ed8;
            margin-bottom: 6px;
        }

        .subtitle {
            font-size: 14px;
            color: #64748b;
            margin-bottom: 18px;
        }

        .controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 12px 14px;
            margin-bottom: 14px;
        }

        .month {
            font-size: 18px;
            font-weight: 700;
            color: #1e3a8a;
        }

        .btn {
            border: 1px solid #cbd5e1;
            background: #fff;
            color: #1e3a8a;
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
        }

        .calendar-wrap { overflow-x: auto; }

        .calendar {
            min-width: 840px;
            display: grid;
            grid-template-columns: repeat(7, minmax(120px, 1fr));
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
        }

        .head {
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
            text-align: center;
            padding: 10px;
            font-size: 12px;
            font-weight: 700;
            color: #475569;
        }

        .cell {
            min-height: 126px;
            border-right: 1px solid #e2e8f0;
            border-bottom: 1px solid #e2e8f0;
            padding: 8px;
            font-size: 12px;
        }

        .cell:nth-child(7n) { border-right: none; }

        .day {
            font-weight: 600;
            color: #334155;
            margin-bottom: 8px;
        }

        .chip {
            display: block;
            background: #dbeafe;
            color: #1d4ed8;
            border-radius: 999px;
            padding: 3px 7px;
            font-size: 11px;
            margin-bottom: 5px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .upcoming {
            margin-top: 16px;
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 14px;
        }

        .upcoming-title {
            font-size: 16px;
            font-weight: 700;
            color: #1e3a8a;
            margin-bottom: 10px;
        }

        .item {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 10px 12px;
            margin-bottom: 8px;
            display: flex;
            justify-content: space-between;
            gap: 10px;
            font-size: 13px;
        }

        @media (max-width: 768px) {
            .title { font-size: 24px; }
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="nav-container">
            <a href="/">
                <div class="logo-section">
                    <img src="resources/2.png" alt="GIIS Clubs" class="logo">
                </div>
            </a>
            <nav>
                <ul class="nav-links">
                    <li><a href="/">Home</a></li>
                    <li><a href="/explore">Explore Clubs</a></li>
                    <li><a href="/public-calendar">Upcoming Events</a></li>
                    <li><a href="/club-index">Register Club</a></li>
                </ul>
            </nav>
            <div class="nav-actions">
                <% if (isLoggedIn) { %>
                    <a href="/home" class="cta-button">Dashboard</a>
                <% } else { %>
                    <a href="/login" class="cta-button">Login</a>
                <% } %>
            </div>
            <button class="mobile-menu-toggle" id="mobileMenuToggle">Menu</button>
        </div>
    </header>

    <div class="mobile-nav-overlay" id="mobileOverlay"></div>
    <nav class="mobile-nav" id="mobileNav">
        <div class="mobile-nav-header">
            <div class="logo-section">
                <img src="resources/2.png" alt="GIIS Clubs" class="logo" style="height:42px">
            </div>
            <button class="mobile-nav-close" id="mobileNavClose">Close</button>
        </div>
        <ul class="mobile-nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/explore">Explore Clubs</a></li>
            <li><a href="/public-calendar">Upcoming Events</a></li>
            <li><a href="/club-index">Register Club</a></li>
        </ul>
        <div class="mobile-nav-cta">
            <% if (isLoggedIn) { %>
                <a href="/home" class="cta-button">Dashboard</a>
            <% } else { %>
                <a href="/login" class="cta-button">Login</a>
            <% } %>
        </div>
    </nav>

    <main class="wrap" style="padding-top: 110px;">
        <h1 class="title">Public Upcoming Events Calendar</h1>
        <p class="subtitle">Anyone can view upcoming approved GIIS club events here without logging in.</p>

        <div class="controls">
            <button class="btn" onclick="changeMonth(-1)">← Previous</button>
            <div id="monthTitle" class="month"></div>
            <button class="btn" onclick="changeMonth(1)">Next →</button>
        </div>

        <div class="calendar-wrap">
            <div id="calendar" class="calendar"></div>
        </div>

        <section class="upcoming">
            <div class="upcoming-title">Coming Up</div>
            <div id="upcomingList"></div>
        </section>
    </main>

    <script>
        const events = <%- JSON.stringify(events || []) %>;
        let viewDate = new Date();

        function formatDateDDMMYYYY(dateString) {
            const date = new Date(dateString);
            const day = String(date.getDate()).padStart(2, '0');
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const year = date.getFullYear();
            return `${day}/${month}/${year}`;
        }

        function renderCalendar() {
            const calendar = document.getElementById('calendar');
            const monthTitle = document.getElementById('monthTitle');

            const year = viewDate.getFullYear();
            const month = viewDate.getMonth();
            const firstDay = new Date(year, month, 1);
            const firstWeekday = firstDay.getDay();
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            monthTitle.textContent = viewDate.toLocaleString('en-US', { month: 'long', year: 'numeric' });

            const labels = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
            const byDay = {};

            events.forEach((event) => {
                const d = new Date(event.date);
                if (d.getFullYear() === year && d.getMonth() === month) {
                    const day = d.getDate();
                    if (!byDay[day]) byDay[day] = [];
                    byDay[day].push(event);
                }
            });

            const header = labels.map(label => `<div class="head">${label}</div>`).join('');
            let body = '';

            for (let i = 0; i < firstWeekday; i++) {
                body += '<div class="cell"></div>';
            }

            for (let day = 1; day <= daysInMonth; day++) {
                const dayEvents = byDay[day] || [];
                const chips = dayEvents.slice(0, 3).map(event => `
                    <span class="chip" title="${event.event_name || event.description}">${event.event_name || event.description}</span>
                `).join('');
                const extra = dayEvents.length > 3 ? `<span class="chip">+${dayEvents.length - 3} more</span>` : '';

                body += `
                    <div class="cell">
                        <div class="day">${day}</div>
                        ${chips}
                        ${extra}
                    </div>
                `;
            }

            calendar.innerHTML = header + body;
        }

        function renderUpcoming() {
            const upcomingList = document.getElementById('upcomingList');
            const today = new Date();
            today.setHours(0, 0, 0, 0);

            const upcoming = events
                .filter(event => new Date(event.date) >= today)
                .sort((a, b) => new Date(a.date) - new Date(b.date))
                .slice(0, 12);

            if (upcoming.length === 0) {
                upcomingList.innerHTML = '<div class="item">No upcoming approved events.</div>';
                return;
            }

            upcomingList.innerHTML = upcoming.map(event => `
                <div class="item">
                    <div>
                        <strong>${event.event_name || event.description}</strong><br>
                        ${event.club}${event.target_grades ? ` • Grades: ${event.target_grades}` : ''}
                    </div>
                    <div>${formatDateDDMMYYYY(event.date)}</div>
                </div>
            `).join('');
        }

        function changeMonth(step) {
            viewDate = new Date(viewDate.getFullYear(), viewDate.getMonth() + step, 1);
            renderCalendar();
        }

        renderCalendar();
        renderUpcoming();
    </script>

    <script>
        const mobileMenuToggle = document.getElementById('mobileMenuToggle');
        const mobileNav = document.getElementById('mobileNav');
        const mobileOverlay = document.getElementById('mobileOverlay');
        const mobileNavClose = document.getElementById('mobileNavClose');

        function openMobileNav() {
            mobileNav.classList.add('open');
            mobileOverlay.classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function closeMobileNav() {
            mobileNav.classList.remove('open');
            mobileOverlay.classList.remove('open');
            document.body.style.overflow = '';
        }

        mobileMenuToggle?.addEventListener('click', openMobileNav);
        mobileNavClose?.addEventListener('click', closeMobileNav);
        mobileOverlay?.addEventListener('click', closeMobileNav);

        document.querySelectorAll('.mobile-nav-links a').forEach(link => {
            link.addEventListener('click', closeMobileNav);
        });
    </script>
</body>
</html>
